package ontology.rules.v1_0

import com.example.ontology.model.UnemployedPerson;
import com.example.ontology.model.InsuranceRecord;
import com.example.ontology.model.InsuranceRecord.StopReason;
import com.example.ontology.model.UnemploymentRegistration;
import com.example.ontology.model.TerminationMaterial;
import com.example.ontology.model.EmployerUnit;
import com.example.ontology.model.BankAccount;
import com.example.ontology.model.EligibilityResult;
import com.example.ontology.model.UnemploymentPolicy;
import com.example.ontology.model.UnemploymentTimeline;

// ============================================================
// Rule 1: 情形一 — 一般职工，缴费 ≥ minContributionMonths
// 单位类型非个体工商户，累计缴费月数 ≥ 政策最低门槛，停保原因非本人意愿
// ============================================================
rule "Unemployment_Scenario_1_GeneralEmployee"
    when
        // 1. 获取当前生效的政策单例
        $policy : UnemploymentPolicy()

        // 2. 申请人：户籍深圳，非临近退休，且未达法定退休年龄
        $p : UnemployedPerson(
            isDomicileShenzhen() == true,
            isRetired($policy) == false,
            isNearRetirement($policy) == false
        )

        // 3. 时间线：定位申请人的最后一段参保记录（日期排序已在本体层完成）
        $timeline : UnemploymentTimeline(getPersonId() == $p.getId())

        // 4. 锁定最后参保记录，验证资格条件
        $latest : InsuranceRecord(
            this == $timeline.getLatestRecord(),
            isLastInsuredShenzhen() == true,
            isInvoluntaryStop() == true,
            getRemainingMonths() > 0
        )

        // 5. 累计缴费月数达到政策门槛（跨多段叠加，由时间线聚合）
        eval($timeline.getTotalMonths() >= $policy.getMinContributionMonths())

        // 6. 用人单位：非个体工商户
        $unit : EmployerUnit(
            getApplicantId() == $p.getId(),
            isIndividualBusiness() == false
        )

        // 7. 失业登记有效
        $reg : UnemploymentRegistration(
            getApplicantId() == $p.getId(),
            isRegistered() == true
        )

        // 8. 终止材料已提交
        $mat : TerminationMaterial(getApplicantId() == $p.getId())
    then
        System.out.println("[RULE][PASS] Scenario-1 GeneralEmployee");
        System.out.println("  applicant : " + $p.getName() + " (" + $p.getId() + ")");
        System.out.println("  timeline  : totalMonths=" + $timeline.getTotalMonths() + "  latestStop=" + $latest.getStopDate());
        System.out.println("  latest    : paid=" + $latest.getPaidMonths() + "m  remaining=" + $latest.getRemainingMonths() + "m  involuntary=" + $latest.isInvoluntaryStop());
        System.out.println("  policy    : minMonths=" + $policy.getMinContributionMonths());
        System.out.println("  unit      : " + $unit.getUnitName() + " [" + $unit.getUnitType() + "]");
        System.out.println("  reg       : valid=" + $reg.isRegistered() + "  date=" + $reg.getRegistrationDate());
        System.out.println("  material  : type=" + $mat.getMaterialType() + "  date=" + $mat.getTerminationDate());
        insert(new EligibilityResult($p.getId(), "ELIGIBLE_SCENARIO_1", "符合一般职工申领条件"));
end

// ============================================================
// Rule 2: 情形二 — 缴费不满 minContributionMonths 但有剩余领取期限
// 单位类型非个体工商户，累计缴费月数 < 政策最低门槛，最后记录剩余月数 > 0
// ============================================================
rule "Unemployment_Scenario_2_ShortTenure"
    when
        $policy : UnemploymentPolicy()

        $p : UnemployedPerson(
            isDomicileShenzhen() == true,
            isRetired($policy) == false,
            isNearRetirement($policy) == false
        )

        $timeline : UnemploymentTimeline(getPersonId() == $p.getId())

        $latest : InsuranceRecord(
            this == $timeline.getLatestRecord(),
            isLastInsuredShenzhen() == true,
            isInvoluntaryStop() == true,
            getRemainingMonths() > 0
        )

        // 累计缴费月数未达政策门槛（有剩余期限则仍可申领）
        eval($timeline.getTotalMonths() < $policy.getMinContributionMonths())

        $unit : EmployerUnit(
            getApplicantId() == $p.getId(),
            isIndividualBusiness() == false
        )

        $reg : UnemploymentRegistration(
            getApplicantId() == $p.getId(),
            isRegistered() == true
        )

        $mat : TerminationMaterial(getApplicantId() == $p.getId())
    then
        System.out.println("[RULE][PASS] Scenario-2 ShortTenure");
        System.out.println("  applicant : " + $p.getName() + " (" + $p.getId() + ")");
        System.out.println("  timeline  : totalMonths=" + $timeline.getTotalMonths() + "  latestStop=" + $latest.getStopDate());
        System.out.println("  latest    : paid=" + $latest.getPaidMonths() + "m  remaining=" + $latest.getRemainingMonths() + "m  involuntary=" + $latest.isInvoluntaryStop());
        System.out.println("  policy    : minMonths=" + $policy.getMinContributionMonths());
        System.out.println("  unit      : " + $unit.getUnitName() + " [" + $unit.getUnitType() + "]");
        System.out.println("  reg       : valid=" + $reg.isRegistered() + "  date=" + $reg.getRegistrationDate());
        System.out.println("  material  : type=" + $mat.getMaterialType() + "  date=" + $mat.getTerminationDate());
        insert(new EligibilityResult($p.getId(), "ELIGIBLE_SCENARIO_2", "符合缴费不足但有剩余期限申领条件"));
end

// ============================================================
// Rule 3: 情形三 — 临近退休人员（距法定退休年龄不足 nearRetirementYears 年）
// 单位类型非个体工商户，申请人动态判定临近退休，停保非本人意愿
// ============================================================
rule "Unemployment_Scenario_3_NearRetirement"
    when
        // 1. 获取当前生效的政策单例（含退休年龄和临近退休年限）
        $policy : UnemploymentPolicy()

        // 2. 判定个人是否符合临近退休条件（已退休者排除，逻辑已封装在 UnemployedPerson 类中）
        $p : UnemployedPerson(
            isDomicileShenzhen() == true,
            isRetired($policy) == false,
            isNearRetirement($policy) == true
        )

        // 3. 时间线：定位最后参保记录
        $timeline : UnemploymentTimeline(getPersonId() == $p.getId())

        // 4. 锁定最后参保记录，验证深圳参保且停保非本人意愿
        $latest : InsuranceRecord(
            this == $timeline.getLatestRecord(),
            isLastInsuredShenzhen() == true,
            isInvoluntaryStop() == true
        )

        // 5. 满足缴费条件：累计达标或最后一段有剩余期限
        eval($timeline.getTotalMonths() >= $policy.getMinContributionMonths()
             || $latest.getRemainingMonths() > 0)

        // 6. 用人单位：非个体工商户
        $unit : EmployerUnit(
            getApplicantId() == $p.getId(),
            isIndividualBusiness() == false
        )

        // 7. 失业登记有效
        $reg : UnemploymentRegistration(
            getApplicantId() == $p.getId(),
            isRegistered() == true
        )

        // 8. 终止材料已提交
        $mat : TerminationMaterial(getApplicantId() == $p.getId())
    then
        System.out.println("[RULE][PASS] Scenario-3 NearRetirement");
        System.out.println("  applicant : " + $p.getName() + " (" + $p.getId() + ")");
        System.out.println("  timeline  : totalMonths=" + $timeline.getTotalMonths() + "  latestStop=" + $latest.getStopDate());
        System.out.println("  latest    : paid=" + $latest.getPaidMonths() + "m  remaining=" + $latest.getRemainingMonths() + "m  involuntary=" + $latest.isInvoluntaryStop());
        System.out.println("  policy    : maleRetire=" + $policy.getMaleRetirementAge() + "  femaleRetire=" + $policy.getFemaleRetirementAge() + "  nearYears=" + $policy.getNearRetirementYears());
        System.out.println("  unit      : " + $unit.getUnitName() + " [" + $unit.getUnitType() + "]");
        System.out.println("  reg       : valid=" + $reg.isRegistered() + "  date=" + $reg.getRegistrationDate());
        System.out.println("  material  : type=" + $mat.getMaterialType() + "  date=" + $mat.getTerminationDate());
        insert(new EligibilityResult($p.getId(), "ELIGIBLE_SCENARIO_3", "符合临近退休人员申领条件"));
end

// ============================================================
// Rule 4: 情形四 — 个体工商户业主
// 通过 EmployerUnit.isIndividualBusiness() 判定，不使用硬编码代码 "81"
// ============================================================
rule "Unemployment_Scenario_4_IndividualBusiness"
    when
        $policy : UnemploymentPolicy()

        $p : UnemployedPerson(isDomicileShenzhen() == true,
                              isRetired($policy) == false)

        $timeline : UnemploymentTimeline(getPersonId() == $p.getId())

        $latest : InsuranceRecord(
            this == $timeline.getLatestRecord(),
            isLastInsuredShenzhen() == true,
            isInvoluntaryStop() == true
        )

        eval($timeline.getTotalMonths() >= $policy.getMinContributionMonths()
             || $latest.getRemainingMonths() > 0)

        // 个体工商户业主：通过语义化属性判定，不使用代码 "81"
        $unit : EmployerUnit(
            getApplicantId() == $p.getId(),
            isIndividualBusiness() == true
        )

        $reg : UnemploymentRegistration(
            getApplicantId() == $p.getId(),
            isRegistered() == true
        )

        $mat : TerminationMaterial(getApplicantId() == $p.getId())
    then
        System.out.println("[RULE][PASS] Scenario-4 IndividualBusiness");
        System.out.println("  applicant : " + $p.getName() + " (" + $p.getId() + ")");
        System.out.println("  timeline  : totalMonths=" + $timeline.getTotalMonths() + "  latestStop=" + $latest.getStopDate());
        System.out.println("  latest    : paid=" + $latest.getPaidMonths() + "m  remaining=" + $latest.getRemainingMonths() + "m  involuntary=" + $latest.isInvoluntaryStop());
        System.out.println("  unit      : " + $unit.getUnitName() + " [" + $unit.getUnitType() + "]");
        System.out.println("  reg       : valid=" + $reg.isRegistered() + "  date=" + $reg.getRegistrationDate());
        System.out.println("  material  : type=" + $mat.getMaterialType() + "  date=" + $mat.getTerminationDate());
        insert(new EligibilityResult($p.getId(), "ELIGIBLE_SCENARIO_4", "符合个体工商户业主申领条件"));
end

// ============================================================
// Rule 5: 兜底拒绝 — 不满足以上任一情形，输出详细拒绝原因
// ============================================================
rule "Unemployment_Rejected"
    when
        $policy : UnemploymentPolicy()
        $p    : UnemployedPerson()
        $timeline : UnemploymentTimeline(getPersonId() == $p.getId())
        $latest   : InsuranceRecord(this == $timeline.getLatestRecord())
        $unit : EmployerUnit(              getApplicantId() == $p.getId())
        $reg  : UnemploymentRegistration(  getApplicantId() == $p.getId())
        $mat  : TerminationMaterial(       getApplicantId() == $p.getId())
        not EligibilityResult(getId() == ($p.getId() + "-ELIG"))
    then
        StringBuilder reason = new StringBuilder();
        if (!$p.isDomicileShenzhen())           reason.append("domicile-not-shenzhen; ");
        if ($p.isRetired($policy))              reason.append("already-retired; ");
        if (!$latest.isLastInsuredShenzhen())   reason.append("last-insured-not-shenzhen; ");
        if (!$latest.meetsPaymentCondition())   reason.append("insufficient-paid-months; ");
        if ($latest.getRemainingMonths() <= 0)  reason.append("no-remaining-months; ");
        if (!$reg.isRegistered())               reason.append("registration-invalid; ");
        if (!$latest.isInvoluntaryStop())       reason.append("voluntary-stop(" + $latest.getStopReason() + "); ");

        System.out.println("[RULE][REJECTED]");
        System.out.println("  applicant : " + $p.getName() + " (" + $p.getId() + ")");
        System.out.println("  unit      : " + $unit.getUnitName() + " [" + $unit.getUnitType() + "]");
        System.out.println("  timeline  : totalMonths=" + $timeline.getTotalMonths() + "  latestStop=" + $latest.getStopDate());
        System.out.println("  latest    : paid=" + $latest.getPaidMonths() + "m  remaining=" + $latest.getRemainingMonths() + "m  stop=" + $latest.getStopReason());
        System.out.println("  reg       : valid=" + $reg.isRegistered());
        System.out.println("  reason    : " + reason.toString());
        insert(new EligibilityResult($p.getId() + "-NOT-ELIG", reason.toString()));
end
